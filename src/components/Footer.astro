---
import TypeMark from "./TypeMark.astro";
import { CONTACT, acceptingProjects } from "../config";

const year = new Date().getFullYear();
const statusText = acceptingProjects
  ? "Currently taking projects"
  : "Booked — check back soon.";
---

<footer class="textured-surface relative border-t border-charcoal/10 bg-sand/40">
  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-8 sm:py-14">
    <div
      class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between"
    >
      <!-- Brand + status -->
      <div>
        <TypeMark variant="header" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-charcoal/70">
          Recording, mixing &amp; mastering for artists in any genre.
        </p>
        <p class="mt-4 flex items-center gap-2 text-sm text-charcoal/70">
          <span
            class="inline-block h-2 w-2 rounded-full"
            class:list={[acceptingProjects ? "bg-burnt" : "bg-charcoal/40"]}
            aria-hidden="true"></span>
          {statusText}
        </p>
      </div>

      <!-- Contact + socials -->
      <div class="flex flex-col gap-5 sm:items-end">
        <a
          href={`mailto:${CONTACT.email}`}
          class="text-sm font-medium text-charcoal underline decoration-burnt/40 decoration-2 underline-offset-4 transition-colors hover:text-burnt hover:decoration-burnt"
        >
          {CONTACT.email}
        </a>

        <ul class="flex items-center gap-1.5">
          <!-- SoundCloud (live) -->
          <li>
            <a
              href={CONTACT.soundcloud}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full text-charcoal/70 transition-colors hover:bg-paper hover:text-burnt"
              aria-label="LRD Production on SoundCloud"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <rect x="1" y="13" width="1.5" height="5" rx="0.75"></rect>
                <rect x="3.6" y="11" width="1.5" height="7" rx="0.75"></rect>
                <rect x="6.2" y="12.5" width="1.5" height="5.5" rx="0.75"></rect>
                <rect x="8.8" y="9" width="1.5" height="9" rx="0.75"></rect>
                <rect x="11.4" y="10.5" width="1.5" height="7.5" rx="0.75"></rect>
                <path
                  d="M14.6 8.6c.6-.3 1.3-.5 2-.5 2.3 0 4.2 1.7 4.5 3.9.1 0 .2-.1.4-.1 1.4 0 2.5 1.1 2.5 2.55C24 16 22.9 18 21.5 18h-6.9z"
                ></path>
              </svg>
            </a>
          </li>
          <!-- Instagram (TODO: real link in config) -->
          <li>
            <a
              href={CONTACT.instagram}
              class="inline-flex h-10 w-10 items-center justify-center rounded-full text-charcoal/70 transition-colors hover:bg-paper hover:text-burnt"
              aria-label="LRD Production on Instagram"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                aria-hidden="true"
              >
                <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
                <circle cx="12" cy="12" r="3.8"></circle>
                <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"
                ></circle>
              </svg>
            </a>
          </li>
          <!-- Spotify (TODO: real link in config) -->
          <li>
            <a
              href={CONTACT.spotify}
              class="inline-flex h-10 w-10 items-center justify-center rounded-full text-charcoal/70 transition-colors hover:bg-paper hover:text-burnt"
              aria-label="LRD Production on Spotify"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.52 17.34c-.24.36-.66.48-1.02.24-2.82-1.74-6.36-2.1-10.56-1.14-.42.12-.78-.18-.9-.54-.12-.42.18-.78.54-.9 4.56-1.02 8.52-.6 11.64 1.32.42.18.48.66.3 1.02zm1.44-3.3c-.3.42-.84.6-1.26.3-3.24-1.98-8.16-2.58-11.94-1.38-.48.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14 4.32-1.32 9.72-.66 13.44 1.62.36.18.54.78.3 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.3c-.6.18-1.2-.18-1.38-.72-.18-.6.18-1.2.72-1.38 4.26-1.26 11.28-1.02 15.72 1.62.54.3.72 1.02.42 1.56-.3.42-1.02.6-1.56.3z"
                ></path>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-charcoal/10 pt-6 text-xs text-charcoal/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} LRD Production</p>
      <p>Built with care in Aurora, Illinois.</p>
    </div>
  </div>

  <!-- Oversized brand watermark -->
  <div
    class="pointer-events-none select-none overflow-hidden"
    aria-hidden="true"
  >
    <p
      class="-mb-[0.12em] whitespace-nowrap text-center font-display text-[18vw] font-medium leading-none text-charcoal/[0.05]"
    >
      LRD Production
    </p>
  </div>
</footer>
