---
/**
 * ServiceCard — a full service offering for the Services page.
 * Big index, title, description, "ideal for" line, CTA to contact.
 * Optional `icon` slot for a small decorative glyph.
 */
interface Props {
  index?: string;
  title: string;
  description: string;
  idealFor: string;
  href?: string;
  ctaLabel?: string;
  class?: string;
}
const {
  index,
  title,
  description,
  idealFor,
  href = "/contact",
  ctaLabel = "Start a project",
  class: className = "",
} = Astro.props;

const hasIcon = Astro.slots.has("icon");
---

<article class:list={["card card-hover flex h-full flex-col p-7 sm:p-9", className]}>
  <div class="flex items-center justify-between">
    {
      hasIcon && (
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-burnt/10 text-burnt">
          <slot name="icon" />
        </div>
      )
    }
    {index && <span class="index-num text-5xl opacity-20">{index}</span>}
  </div>

  <h3 class="mt-6 text-[clamp(1.6rem,3.5vw,2.1rem)] font-medium leading-tight text-charcoal">
    {title}
  </h3>

  <p class="mt-4 leading-relaxed text-charcoal/80">{description}</p>

  <p class="mt-5 border-l-2 border-burnt/40 pl-4 text-sm leading-relaxed text-charcoal/70">
    {idealFor}
  </p>

  <div class="mt-auto pt-8">
    <a
      href={href}
      class="inline-flex items-center gap-2 rounded-full bg-burnt px-6 py-3 text-sm font-semibold text-paper transition-colors hover:bg-oxblood"
    >
      {ctaLabel}
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </a>
  </div>
</article>
