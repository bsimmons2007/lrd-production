---
/**
 * Stat — a single count-up metric. Numeric values count up on scroll
 * (markup holds the final value, so reduced-motion shows it statically).
 * String values render as-is (e.g. "Any").
 */
interface Props {
  value: number | string;
  prefix?: string;
  suffix?: string;
  label: string;
  class?: string;
}
const { value, prefix = "", suffix = "", label, class: className = "" } =
  Astro.props;
const numeric = typeof value === "number";
---

<div class:list={["reveal", className]}>
  <p class="font-display text-5xl font-medium leading-none text-charcoal sm:text-6xl">
    {prefix}{
      numeric ? (
        <span class="count-up" data-to={value}>
          {value}
        </span>
      ) : (
        <span>{value}</span>
      )
    }<span class="text-burnt">{suffix}</span>
  </p>
  <p class="mt-3 text-sm leading-snug text-charcoal/65">{label}</p>
</div>
