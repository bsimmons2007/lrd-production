---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config";

interface Props {
  title?: string;
  description?: string;
  /** Path (relative to /public) or absolute URL to the social preview image. */
  ogImage?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.defaultOgImage,
} = Astro.props;

const pageTitle = title
  ? `${title} — ${SITE.name}`
  : `${SITE.name} — Recording, Mixing & Mastering`;

// Astro.site is set in astro.config.mjs; fall back gracefully in dev.
const base = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, base).href;
const ogImageUrl = new URL(ogImage, base).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#E9F1EF" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#0A7A57" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: preconnect + display=swap for fast, non-blocking loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Inter:wght@400;500;600;700&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="LRD Production — Recording, Mixing, Mastering"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Enable motion only when JS is on AND reduced motion is NOT requested.
         Runs before paint so initial hidden states never flash for others. -->
    <script is:inline>
      if (
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches &&
        !location.search.includes("stillshot")
      ) {
        document.documentElement.classList.add("motion-ok");
      }
    </script>
  </head>

  <body class="flex min-h-svh flex-col">
    <div class="grain-overlay" aria-hidden="true"></div>
    <div class="vignette" aria-hidden="true"></div>
    <div
      id="scroll-progress"
      aria-hidden="true"
      class="fixed inset-x-0 top-0 z-[70] h-[3px] origin-left bg-gradient-to-r from-burnt to-amber"
      style="transform: scaleX(0)"
    >
    </div>

    <a
      href="#main"
      class="sr-only z-50 rounded-md bg-charcoal px-4 py-2 font-medium text-paper focus:not-sr-only focus:absolute focus:left-4 focus:top-4"
    >
      Skip to content
    </a>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <Analytics />
  </body>
</html>
