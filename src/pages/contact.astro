---
import Layout from "../layouts/Layout.astro";
import { CONTACT, FORMSPREE_ID } from "../config";

const formAction = `https://formspree.io/f/${FORMSPREE_ID}`;
const inputClass =
  "w-full rounded-lg border border-charcoal/20 bg-paper px-4 py-3 text-charcoal placeholder-charcoal/40 transition-colors focus:border-burnt focus:outline-none focus-visible:outline-none";
const labelClass = "mb-1.5 block text-sm font-medium text-charcoal";
---

<Layout
  title="Contact"
  description="Book recording, mixing, mastering, or production with LRD Production. Tell me about your project and I'll get back to you."
>
  <section class="mx-auto max-w-2xl px-5 py-16 sm:px-8 sm:py-20">
    <div class="reveal-group">
      <p class="reveal eyebrow">Contact</p>
      <h1 class="reveal mt-3 text-4xl font-medium text-charcoal sm:text-5xl">
        Let's make something
      </h1>
      <p class="reveal mt-4 text-lg leading-relaxed text-charcoal/80">
        Interested in collaborating or booking a service? Drop your info below
        and I'll get back to you as soon as I can. Looking forward to
        connecting.
      </p>
    </div>

    <!-- Success state (revealed after submit) -->
    <div
      id="form-success"
      role="status"
      class="mt-10 hidden rounded-2xl border border-burnt/30 bg-burnt/5 p-8 text-center"
    >
      <div
        class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-burnt text-paper"
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 6L9 17l-5-5"></path>
        </svg>
      </div>
      <h2 class="mt-4 text-2xl font-medium text-charcoal">Message sent</h2>
      <p class="mt-2 text-charcoal/75">
        Thanks for reaching out — I'll be in touch soon.
      </p>
    </div>

    <!-- TODO: Logan create a free Formspree account, paste form ID into
         src/config.ts (FORMSPREE_ID). Until then submissions will error. -->
    <form
      id="contact-form"
      action={formAction}
      method="POST"
      class="mt-10 grid gap-5"
    >
      <!-- Honeypot: hidden from humans, catches bots. Formspree ignores _gotcha. -->
      <div class="sr-only" aria-hidden="true">
        <label for="_gotcha">Leave this field empty</label>
        <input
          type="text"
          id="_gotcha"
          name="_gotcha"
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="name" class={labelClass}>
            Name <span class="text-burnt" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class={inputClass}
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class={labelClass}>
            Email <span class="text-burnt" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class={inputClass}
            placeholder="you@email.com"
          />
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="project-type" class={labelClass}>
            Project type <span class="text-burnt" aria-hidden="true">*</span>
          </label>
          <select
            id="project-type"
            name="project type"
            required
            class={inputClass}
          >
            <option value="" disabled selected>Choose one…</option>
            <option>Recording</option>
            <option>Mixing &amp; Mastering</option>
            <option>Production</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label for="genre" class={labelClass}>Genre</label>
          <input
            type="text"
            id="genre"
            name="genre"
            class={inputClass}
            placeholder="Rock, hip-hop, 8-bit…"
          />
        </div>
      </div>

      <div>
        <label for="budget" class={labelClass}>Rough budget</label>
        <select id="budget" name="rough budget" class={inputClass}>
          <option value="" disabled selected>Pick a range…</option>
          <option>Under $100</option>
          <option>$100–300</option>
          <option>$300+</option>
          <option>Not sure</option>
        </select>
      </div>

      <div>
        <label for="message" class={labelClass}>
          Message <span class="text-burnt" aria-hidden="true">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          class={inputClass}
          placeholder="Tell me about your project — what you're making, where it's at, and what you need."
        ></textarea>
      </div>

      <p
        id="form-error"
        class="hidden text-sm font-medium text-oxblood"
        role="alert"
      >
        Something went wrong sending your message. Please email me directly
        instead.
      </p>

      <div class="flex items-center gap-3">
        <button type="submit" id="submit-btn" class="btn-primary">
          Send message
        </button>
        <span id="submit-pending" class="hidden text-sm text-charcoal/60"
          >Sending…</span
        >
      </div>
    </form>

    <!-- Fallback contact -->
    <div class="mt-12 border-t border-charcoal/10 pt-8">
      <p class="text-sm text-charcoal/60">Prefer to keep it simple?</p>
      <div class="mt-3 flex flex-wrap items-center gap-4">
        <a href={`mailto:${CONTACT.email}`} class="btn-secondary">
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
          Or just email me
        </a>
        <a
          href={CONTACT.soundcloud}
          target="_blank"
          rel="noopener noreferrer"
          class="link-arrow"
        >
          Listen on SoundCloud
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17 17 7M8 7h9v9"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { initReveals } from "../scripts/motion";
  initReveals();

  // Progressive enhancement: submit via fetch for an inline success state.
  // Without JS, the form still POSTs to Formspree normally.
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const success = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");
  const pending = document.getElementById("submit-pending");
  const submitBtn = document.getElementById(
    "submit-btn",
  ) as HTMLButtonElement | null;

  if (form && success && errorEl) {
    form.addEventListener("submit", async (e) => {
      // Let native validation run first.
      if (!form.checkValidity()) return;
      e.preventDefault();

      errorEl.classList.add("hidden");
      pending?.classList.remove("hidden");
      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.classList.add("hidden");
          success.classList.remove("hidden");
          success.scrollIntoView({ behavior: "smooth", block: "center" });
        } else {
          throw new Error("Bad response");
        }
      } catch {
        errorEl.classList.remove("hidden");
      } finally {
        pending?.classList.add("hidden");
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
