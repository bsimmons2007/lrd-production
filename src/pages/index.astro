---
import Layout from "../layouts/Layout.astro";
import TypeMark from "../components/TypeMark.astro";
import StatusBadge from "../components/StatusBadge.astro";
import Equalizer from "../components/Equalizer.astro";
import Marquee from "../components/Marquee.astro";
import Stat from "../components/Stat.astro";
import CTABand from "../components/CTABand.astro";
import { SITE, FEATURED_TRACK_SLUG, soundcloudEmbed } from "../config";

const genres = [
  "Rock",
  "Country",
  "Hip-Hop",
  "8-Bit",
  "Retro Game",
  "Pop",
  "R&B",
  "Experimental",
];
---

<Layout>
  <!-- ============================ HERO ============================ -->
  <section id="hero" class="relative overflow-hidden">
    <div class="aurora-glow" aria-hidden="true"></div>
    <div class="hero-grain" aria-hidden="true"></div>

    <!-- Console corner annotations -->
    <div
      class="hero-meta pointer-events-none absolute inset-x-0 top-0 z-10 flex items-center justify-between px-5 pt-5 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-charcoal/45 sm:px-8 sm:pt-7"
    >
      <span class="inline-flex items-center gap-2">
        <span class="rec-dot inline-block h-2 w-2 rounded-full bg-burnt"></span>
        Rec
      </span>
      <span>Aurora, IL</span>
    </div>

    <div
      class="relative mx-auto flex min-h-[88svh] max-w-4xl flex-col items-center justify-center px-5 py-24 text-center"
    >
      <h1 class="leading-none">
        <span class="sr-only">LRD Production</span>
        <span aria-hidden="true" class="block">
          <TypeMark variant="hero" />
        </span>
      </h1>

      <!-- Needle-trace divider draws itself on load -->
      <svg
        class="mt-9 h-7 w-[min(420px,78%)]"
        viewBox="0 0 240 40"
        preserveAspectRatio="none"
        fill="none"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="aurora-line" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#0a7a57"></stop>
            <stop offset="0.5" stop-color="#1fb6be"></stop>
            <stop offset="1" stop-color="#3b82c4"></stop>
          </linearGradient>
        </defs>
        <path
          class="hero-line"
          d="M0 20 Q 15 6 30 20 T 60 20 T 90 20 T 120 20 T 150 20 T 180 20 T 210 20 T 240 20"
          stroke="url(#aurora-line)"
          stroke-width="2.5"
          stroke-linecap="round"></path>
      </svg>

      <p
        class="hero-tagline mt-9 max-w-xl text-lg leading-relaxed text-charcoal/80 sm:text-xl"
      >
        {SITE.tagline}
      </p>

      <div class="hero-badge mt-9 flex items-center gap-4">
        <StatusBadge />
        <Equalizer bars={5} class="hidden h-6 sm:inline-flex" />
      </div>

      <div class="hero-cta mt-9 flex flex-col items-center gap-5 sm:flex-row">
        <a href="/contact" class="btn-primary magnetic">Get in touch</a>
        <a href="/portfolio" class="link-arrow">
          Hear the work
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
      </div>

      <!-- Scroll cue -->
      <div
        class="hero-meta absolute bottom-7 left-1/2 -translate-x-1/2 font-mono text-[0.62rem] uppercase tracking-[0.2em] text-charcoal/40"
      >
        <span class="scroll-cue inline-flex flex-col items-center gap-1">
          Scroll
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 5v14M6 13l6 6 6-6"></path>
          </svg>
        </span>
      </div>
    </div>
  </section>

  <!-- ========================= GENRE MARQUEE ====================== -->
  <div class="textured-surface border-y border-charcoal/12 bg-sand/30 py-5">
    <Marquee items={genres} duration="40s" />
  </div>

  <!-- ============================ STATS =========================== -->
  <section class="reveal-group mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-20">
    <div class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4">
      <Stat value={10} suffix="+" label="Years behind the piano" />
      <Stat value={5} suffix="+" label="Years in the audio arts" />
      <Stat value={4} label="DAWs in rotation" />
      <Stat value="Any" label="Genre, any challenge" />
    </div>
  </section>

  <!-- ======================== NOW PLAYING ========================= -->
  <section class="reveal-group mx-auto max-w-4xl px-5 py-16 sm:px-8 sm:py-20">
    <p class="reveal eyebrow">Featured track</p>
    <h2 class="reveal-text mt-5 text-[clamp(2.25rem,6vw,4rem)] font-medium leading-[0.98] text-charcoal">
      Straight from the catalogue
    </h2>

    <div class="reveal card mt-10 p-5 sm:p-7">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div class="flex items-center gap-4">
          <Equalizer bars={6} class="h-8" />
          <div>
            <p class="eyebrow eyebrow--bare mb-1 !text-charcoal/40">
              Now playing
            </p>
            <p class="font-display text-2xl font-medium text-charcoal sm:text-3xl">
              Cirrus
            </p>
          </div>
        </div>
        <a href="/portfolio" class="link-arrow hidden sm:inline-flex">
          All tracks
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
      </div>
      <div class="overflow-hidden rounded-xl">
        <iframe
          src={soundcloudEmbed(FEATURED_TRACK_SLUG)}
          title="Cirrus — SoundCloud player"
          width="100%"
          height="166"
          frameborder="no"
          loading="lazy"
          scrolling="no"
          allow="autoplay"
          class="block w-full"></iframe>
      </div>
    </div>
  </section>

  <!-- ========================== SERVICES ========================== -->
  <section class="reveal-group mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-20">
    <p class="reveal eyebrow">What I do</p>
    <h2 class="reveal-text mt-5 max-w-2xl text-[clamp(2.25rem,6vw,4rem)] font-medium leading-[0.98] text-charcoal">
      Two ways I can help
    </h2>

    <div
      class="reveal mt-12 grid overflow-hidden rounded-2xl border border-charcoal/12 sm:grid-cols-2"
    >
      <a
        href="/services"
        class="group relative flex flex-col p-8 transition-colors duration-300 hover:bg-sand/45 sm:p-10"
      >
        <span class="index-num text-3xl opacity-25">01</span>
        <h3 class="mt-4 text-2xl font-medium text-charcoal sm:text-3xl">
          Recording
        </h3>
        <p class="mt-3 max-w-sm leading-relaxed text-charcoal/75">
          Clean, usable takes — set up and captured in the room, or guided
          through doing it yourself.
        </p>
        <span class="link-arrow mt-6">
          Explore services
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </span>
      </a>

      <a
        href="/services"
        class="group relative flex flex-col border-t border-charcoal/12 p-8 transition-colors duration-300 hover:bg-sand/45 sm:border-l sm:border-t-0 sm:p-10"
      >
        <span class="index-num text-3xl opacity-25">02</span>
        <h3 class="mt-4 text-2xl font-medium text-charcoal sm:text-3xl">
          Mixing &amp; Mastering
        </h3>
        <p class="mt-3 max-w-sm leading-relaxed text-charcoal/75">
          Balanced, polished, and finished — production assistance included when
          you want it.
        </p>
        <span class="link-arrow mt-6">
          Explore services
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </span>
      </a>
    </div>
  </section>

  <!-- ========================= ABOUT TEASER ======================= -->
  <section
    class="reveal-group mx-auto max-w-4xl px-5 py-20 text-center sm:px-8 sm:py-28"
  >
    <p class="reveal eyebrow eyebrow--center">The story</p>
    <blockquote
      class="reveal-text mt-6 font-display text-[clamp(1.6rem,4vw,2.6rem)] font-medium leading-snug text-charcoal"
    >
      I'm an aspiring audio engineer based in Aurora, Illinois, with over a
      decade behind the piano. There's more to the story.
    </blockquote>
    <div class="reveal mt-9">
      <a href="/about" class="btn-secondary magnetic">Learn more</a>
    </div>
  </section>

  <!-- =========================== CTA BAND ========================= -->
  <CTABand title="Got a track? Let's finish it." buttonLabel="Get in touch" />
</Layout>

<script>
  import { initMotion } from "../scripts/motion";
  initMotion();
</script>
