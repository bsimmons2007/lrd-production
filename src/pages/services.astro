---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTABand from "../components/CTABand.astro";

// TODO: Logan — tweak these steps + answers to match how you actually work.
const steps = [
  {
    title: "Reach out",
    body: "Tell me about your project — what you're making, where it's at, and what you need.",
  },
  {
    title: "Quote & plan",
    body: "I'll scope the work and send a clear quote and timeline before anything starts.",
  },
  {
    title: "Record or send",
    body: "Track in the room together, or send me your stems — whatever fits your setup.",
  },
  {
    title: "Mix & revise",
    body: "I shape the sound, you review, and we refine it until it feels right.",
  },
  {
    title: "Master & deliver",
    body: "You get a polished master, formatted and ready to release.",
  },
];

const faqs = [
  {
    q: "Do you work remotely?",
    a: "Yes — send your stems or files and we can work from anywhere. I'm also available for in-person sessions around Aurora, Illinois.",
  },
  {
    q: "What genres do you take on?",
    a: "Any — rock, country, hip-hop, pop, and even 8-bit and retro game music. I'd rather stay versatile than box myself in.",
  },
  {
    q: "What do you need from me to mix?",
    a: "Clearly labeled stems or multitracks, any reference tracks you like, and notes on the vibe you're going for.",
  },
  {
    q: "How many revisions are included?",
    a: "We'll agree on a revision count up front — the goal is for you to be genuinely happy with the result.",
  },
  {
    q: "How long does it take?",
    a: "It depends on scope. I'll give you a realistic timeline along with your quote.",
  },
  {
    q: "How much does it cost?",
    a: "Pricing varies by project. Reach out with the details and I'll send a free quote.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title="Services"
  description="Recording, mixing, and mastering with LRD Production. Hands-on tracking support and polished, release-ready mixes for any genre."
>
  <section class="reveal-group mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
    <p class="reveal eyebrow">Services</p>
    <h1 class="reveal-text mt-5 text-[clamp(2.5rem,8vw,5rem)] font-medium leading-[0.95] text-charcoal">
      What I offer
    </h1>
    <p class="reveal mt-5 max-w-xl text-lg leading-relaxed text-charcoal/75">
      Two focused services, one goal — getting your music sounding its best.
    </p>

    <div class="mt-12 grid items-stretch gap-5 md:grid-cols-2 md:gap-6">
      <div class="reveal h-full">
        <ServiceCard
          index="01"
          title="Recording"
          description="Need a recording engineer in your corner? Whether it's vocals, drums, or a full session, I'll set up the room and capture clean, usable takes — or walk you through doing it yourself."
          idealFor="Ideal if you want hands-on recording support without the guesswork."
        >
          <svg
            slot="icon"
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="9" y="2" width="6" height="11" rx="3"></rect>
            <path d="M5 10a7 7 0 0 0 14 0"></path>
            <path d="M12 17v4M8 21h8"></path>
          </svg>
        </ServiceCard>
      </div>

      <div class="reveal h-full">
        <ServiceCard
          index="02"
          title="Mixing & Mastering"
          description="Got tracks that need to sound finished? I handle mixing and mastering — balancing, polishing, and production assistance when you want it — to make your music sound its best."
          idealFor="Perfect for taking any audio project across the finish line."
        >
          <svg
            slot="icon"
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 6h8M18 6h2M4 12h2M10 12h10M4 18h10M18 18h2"></path>
            <circle cx="15" cy="6" r="2"></circle>
            <circle cx="8" cy="12" r="2"></circle>
            <circle cx="15" cy="18" r="2"></circle>
          </svg>
        </ServiceCard>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="reveal-group mx-auto max-w-6xl px-5 pb-6 sm:px-8">
    <p class="reveal eyebrow">How it works</p>
    <h2 class="reveal-text mt-5 text-[clamp(2rem,5vw,3.25rem)] font-medium leading-[0.98] text-charcoal">
      From first message to final master
    </h2>
    <ol class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {
        steps.map((s, i) => (
          <li class="reveal card card-hover flex flex-col p-6">
            <span class="index-num text-2xl opacity-30">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="mt-3 text-lg font-medium text-charcoal">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-charcoal/75">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- FAQ -->
  <section class="reveal-group mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-20">
    <p class="reveal eyebrow">FAQ</p>
    <h2 class="reveal-text mt-5 text-[clamp(2rem,5vw,3.25rem)] font-medium leading-[0.98] text-charcoal">
      Questions, answered
    </h2>
    <div class="mt-9 border-t border-charcoal/10">
      {
        faqs.map((f) => (
          <details class="faq-item reveal border-b border-charcoal/10">
            <summary class="flex cursor-pointer items-center justify-between gap-4 py-5 text-lg font-medium text-charcoal">
              {f.q}
              <svg
                class="faq-chevron h-5 w-5 shrink-0 text-burnt"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M6 9l6 6 6-6" />
              </svg>
            </summary>
            <p class="-mt-1 pb-5 leading-relaxed text-charcoal/75">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(faqJsonLd)}
  />

  <CTABand
    eyebrow="Ready when you are"
    title="Tell me about your project."
    buttonLabel="Start a project"
  />
</Layout>

<script>
  import { initMotion } from "../scripts/motion";
  initMotion();
</script>
